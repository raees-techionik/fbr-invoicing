// FBR E-Invoicing — multi-tenant: users belong to one or more companies (business + optional personal workspace)

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum CompanyKind {
  PERSONAL
  BUSINESS
}

/// Role within a company (maps to SOW: Customer Admin, Sub-User, Accountant/Viewer)
enum MembershipRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum CompanyInvitationStatus {
  PENDING
  ACCEPTED
  REVOKED
  EXPIRED
}

enum InvitationEmailStatus {
  NOT_SENT
  SENT
  FAILED
  DEV_LOGGED
}

enum FbrOnboardingStatus {
  PROFILE_PENDING
  PRODUCT_MAPPING_PENDING
  IRIS_REGISTRATION_PENDING
  IP_WHITELIST_PENDING
  SANDBOX_TOKEN_PENDING
  SANDBOX_TESTING
  CLIENT_TESTING
  PRODUCTION_TOKEN_PENDING
  READY_FOR_LIVE
  LIVE
  SUSPENDED
}

enum FbrApprovalStatus {
  NOT_STARTED
  PENDING
  APPROVED
  REJECTED
}

enum FbrTokenStatus {
  MISSING
  REQUESTED
  CONFIGURED
  INVALID
  EXPIRED
}

enum FbrSandboxStatus {
  NOT_STARTED
  IN_PROGRESS
  PASSED
  FAILED
}

enum FbrSandboxResultStatus {
  PASSED
  FAILED
}

enum FbrSandboxOperation {
  VALIDATE
  SUBMIT
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  fullName     String
  phone        String?
  /// Platform operator (full access) — use sparingly
  isSuperAdmin Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  memberships         UserCompanyMembership[]
  sentInvitations     CompanyInvitation[]     @relation("InvitationInviter")
  acceptedInvitations CompanyInvitation[]     @relation("InvitationAccepter")
  companyActivityLogs CompanyActivityLog[]    @relation("CompanyActivityActor")
}

model Company {
  id        String      @id @default(cuid())
  name      String
  kind      CompanyKind
  legalName String?
  ntn       String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  memberships    UserCompanyMembership[]
  profile        CompanyProfile?
  staffMembers   StaffMember[]
  customers      Customer[]
  invoices       Invoice[]
  products       Product[]
  tokens         Token[]
  onboarding     FbrOnboarding?
  sandboxResults SandboxResult[]
  invitations    CompanyInvitation[]
  activityLogs   CompanyActivityLog[]
}

model UserCompanyMembership {
  id        String         @id @default(cuid())
  userId    String
  companyId String
  role      MembershipRole @default(MEMBER)
  isDefault Boolean        @default(false)

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([userId, companyId])
  @@index([userId])
  @@index([companyId])
}

model CompanyInvitation {
  id               String                  @id @default(cuid())
  companyId        String
  email            String
  role             MembershipRole          @default(MEMBER)
  status           CompanyInvitationStatus @default(PENDING)
  tokenHash        String                  @unique
  invitedByUserId  String
  acceptedByUserId String?
  emailStatus      InvitationEmailStatus   @default(NOT_SENT)
  emailSentAt      DateTime?
  emailError       String?
  emailAttemptedAt DateTime?
  expiresAt        DateTime
  acceptedAt       DateTime?
  revokedAt        DateTime?
  createdAt        DateTime                @default(now())

  company    Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invitedBy  User    @relation("InvitationInviter", fields: [invitedByUserId], references: [id], onDelete: Cascade)
  acceptedBy User?   @relation("InvitationAccepter", fields: [acceptedByUserId], references: [id], onDelete: SetNull)

  @@index([companyId, status])
  @@index([companyId, email])
  @@index([email, status])
  @@index([expiresAt])
}

model CompanyActivityLog {
  id          String   @id @default(cuid())
  companyId   String
  actorUserId String?
  action      String
  summary     String
  metadata    Json?
  createdAt   DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  actor   User?   @relation("CompanyActivityActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([companyId, createdAt])
  @@index([companyId, action])
  @@index([actorUserId])
}

model CompanyProfile {
  id           String   @id @default(cuid())
  companyId    String   @unique @default("legacy-default-company")
  companyName  String   @default("")
  ntnOrCnic    String   @default("")
  businessType String   @default("")
  province     String   @default("")
  address      String   @default("")
  phoneNumber  String   @default("")
  emailAddress String   @default("")
  logoBase64   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model StaffMember {
  id          String   @id @default(cuid())
  companyId   String   @default("legacy-default-company")
  memberName  String
  designation String
  cnicNtn     String
  phoneNumber String
  email       String
  province    String
  address     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([companyId, memberName])
  @@index([companyId, email])
}

model Customer {
  id               String   @id @default(cuid())
  companyId        String   @default("legacy-default-company")
  name             String
  cnic             String
  phone            String
  email            String
  province         String
  address          String
  registrationType String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([companyId, name])
  @@index([companyId, cnic])
}

model Invoice {
  id                    String    @id @default(uuid())
  companyId             String    @default("legacy-default-company")
  fbrInvoiceNumber      String?
  invoiceType           String
  invoiceDate           DateTime
  invoiceRefNo          String?
  sellerNTNCNIC         String
  sellerBusinessName    String
  sellerProvince        String
  sellerAddress         String
  buyerNTNCNIC          String?
  buyerBusinessName     String
  buyerProvince         String
  buyerAddress          String
  buyerRegistrationType String
  status                String    @default("DRAFT")
  isOffline             Boolean   @default(false)
  offlineQueuedAt       DateTime?
  submittedAt           DateTime?
  fbrRawResponse        Json?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  company      Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  items        InvoiceItem[]
  offlineQueue OfflineQueue[]

  @@index([companyId])
  @@index([companyId, fbrInvoiceNumber])
  @@index([companyId, invoiceDate])
  @@index([companyId, invoiceType])
  @@index([companyId, status])
  @@index([companyId, isOffline])
}

model InvoiceItem {
  id                              String   @id @default(uuid())
  invoiceId                       String
  fbrItemInvoiceNo                String?
  hsCode                          String
  productDescription              String
  rate                            String
  uom                             String
  quantity                        Float
  totalValues                     Float
  valueSalesExcludingST           Float
  fixedNotifiedValueOrRetailPrice Float
  salesTaxApplicable              Float
  salesTaxWithheldAtSource        Float
  extraTax                        Float?
  furtherTax                      Float?
  sroScheduleNo                   String?
  fedPayable                      Float?
  discount                        Float?
  saleType                        String
  sroItemSerialNo                 String?
  createdAt                       DateTime @default(now())
  updatedAt                       DateTime @updatedAt

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@index([hsCode])
  @@index([saleType])
}

model Product {
  id                   String   @id @default(uuid())
  companyId            String   @default("legacy-default-company")
  name                 String
  hsCode               String
  hsDescription        String
  defaultSaleType      String
  defaultRate          String
  defaultUom           String
  inStock              String?  @default("")
  sroScheduleNo        String?
  furtherTaxApplicable Boolean  @default(false)
  extraTaxApplicable   Boolean  @default(false)
  fedApplicable        Boolean  @default(false)
  isActive             Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([companyId, name])
  @@index([companyId, hsCode])
  @@index([companyId, isActive])
}

model Token {
  id          String   @id @default(uuid())
  companyId   String   @default("legacy-default-company")
  environment String
  token       String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([companyId, environment, isActive])
}

model OfflineQueue {
  id             String    @id @default(uuid())
  invoiceId      String
  invoicePayload Json
  status         String    @default("PENDING")
  queuedAt       DateTime  @default(now())
  uploadedAt     DateTime?
  retryCount     Int       @default(0)
  lastError      String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@index([status])
  @@index([queuedAt])
  @@index([uploadedAt])
}

model ReferenceCache {
  id        String   @id @default(uuid())
  cacheKey  String   @unique
  data      Json
  fetchedAt DateTime
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([expiresAt])
}

model FbrOnboarding {
  id                     String              @id @default(cuid())
  companyId              String              @unique @default("legacy-default-company")
  status                 FbrOnboardingStatus @default(PROFILE_PENDING)
  businessNature         String?
  primarySector          String?
  technicalContactName   String?
  technicalContactMobile String?
  technicalContactEmail  String?
  erpProvider            String              @default("Techionik")
  softwareType           String              @default("Cloud")
  ipWhitelistStatus      FbrApprovalStatus   @default(NOT_STARTED)
  sandboxTokenStatus     FbrTokenStatus      @default(MISSING)
  sandboxStatus          FbrSandboxStatus    @default(NOT_STARTED)
  productionTokenStatus  FbrTokenStatus      @default(MISSING)
  irisSubmittedAt        DateTime?
  ipWhitelistApprovedAt  DateTime?
  sandboxStartedAt       DateTime?
  sandboxCompletedAt     DateTime?
  productionRequestedAt  DateTime?
  goLiveAt               DateTime?
  notes                  String?
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model SandboxResult {
  id            String                 @id @default(cuid())
  companyId     String                 @default("legacy-default-company")
  scenarioId    String
  scenarioName  String?
  operation     FbrSandboxOperation
  status        FbrSandboxResultStatus
  statusCode    String?
  invoiceNumber String?
  payload       Json
  response      Json?
  errors        Json?
  durationMs    Int?
  runAt         DateTime               @default(now())
  passedAt      DateTime?
  createdAt     DateTime               @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([companyId, scenarioId])
  @@index([companyId, status])
  @@index([companyId, runAt])
}
