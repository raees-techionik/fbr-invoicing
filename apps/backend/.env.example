# PostgreSQL (install locally; create DB e.g. fbr_einvoicing)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/fbr_einvoicing"

# Auth (JWT + bcrypt per SOW)
JWT_SECRET="replace-with-a-long-random-string"
JWT_EXPIRES_IN="7d"

PORT=3000

# Optional demo admin login. Use only for demo/staging; create real DB-backed users for production.
ADMIN_EMAIL="admin@fbr.com"
ADMIN_PASSWORD="admin123"
ADMIN_FULL_NAME="Admin"
ADMIN_WORKSPACE_NAME="Admin Workspace"
ALLOW_DEV_ADMIN_LOGIN="false"

# Invitation email delivery. If SMTP_HOST is omitted, invitation emails are logged locally and marked DEV_LOGGED.
APP_BASE_URL="http://localhost:3001"
EMAIL_FROM="no-reply@techionik.com"
EMAIL_FROM_NAME="Techionik FBR Digital Invoicing"
SMTP_HOST=""
SMTP_PORT=587
SMTP_SECURE="false"
SMTP_REQUIRE_TLS="true"
SMTP_USER=""
SMTP_PASSWORD=""
# Optional local/testing escape hatch. Leave false in production.
EXPOSE_DEV_INVITATION_TOKENS="false"

# FBR Digital Invoicing reference APIs
FBR_BASE_URL="https://gw.fbr.gov.pk"
FBR_REFERENCE_API_TOKEN=""
FBR_REFERENCE_CACHE_TTL_SECONDS=86400

# Keep true for local UI/backend development before PRAL token + IP whitelisting are available
FBR_REFERENCE_USE_MOCKS="true"

# FBR invoice validation/submission APIs
FBR_ENVIRONMENT="sandbox"
FBR_SANDBOX_TOKEN=""
FBR_PRODUCTION_TOKEN=""
FBR_REFERENCE_INVOICE_LOOKUP_URL=""
FBR_SETTINGS_ENCRYPTION_KEY="replace-with-a-long-random-string"
FBR_OUTBOUND_IP=""

# Use "file" for local product-mapping demo without PostgreSQL, leave empty/default for Prisma/PostgreSQL.
FBR_PRODUCT_MAPPING_STORAGE="file"

# Use "file" for local dashboard demo without PostgreSQL, leave empty/default for Prisma/PostgreSQL.
FBR_INVOICE_DASHBOARD_STORAGE="file"

# Use "file" for local offline-queue demo without PostgreSQL, leave empty/default for Prisma/PostgreSQL.
FBR_OFFLINE_QUEUE_STORAGE="file"

# Keep true until live FBR sandbox token and IP whitelisting are available
FBR_INVOICE_USE_MOCKS="true"

# Optional: Redis for sessions / queues / rate limits (SOW). If omitted, a JSON file cache is used under .data/cache.json
# REDIS_URL="redis://localhost:6379"

# Optional: override file cache path when REDIS_URL is not set
# CACHE_FILE_PATH=".data/cache.json"
